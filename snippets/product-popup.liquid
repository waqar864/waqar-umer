<div class="popup-product">
    <div class="popup-top">
        <div class="popup-lft-img">

            {% if product.featured_image %}
              <img src="{{ product.featured_image | img_url: '300x300' }}" alt="{{ product.title }}" >
            {% endif %}
        </div>
        <div class="popup-rit-content">

            <h3>{{ product.title }}</h3>
            <p class="popup-price">{{ product.price | money }}</p>
            <p>{{ product.description | strip_html | truncate: 120 }}</p>
        </div>
    </div>


 <form method="post" action="/cart/add" class="popup-form">
  {% for option in product.options_with_values %}
    {% assign downcased = option.name | downcase %}

    {% if downcased contains 'color' %}
        
      <div class="popup-option button_option">
        <label>{{ option.name }}</label>
        <div class="popup-color-buttons">
          {% for value in option.values %}
          
            <button 
              type="button" 
              class="popup-color-btn" 
              name="options[{{ option.name }}]" 
              value="{{ value }}"
              style="
              text-align: left;
              padding: 10px 20px;
              font-size: 16px;
                border: 1px solid #000;
                border-left: 5px solid {{ value | downcase }};
                background-color: #fff;
                color: #000;
                cursor: pointer;
                transition: background-color 0.3s 
                ease, border-left-color 0.3s ease, color 0.3s ease; "
              title="{{ value }}">
              {{ value }}
            </button>
          {% endfor %}
        </div>
      </div>

    {% elsif downcased contains 'size' %}
      <div class="popup-option">
        <label>{{ option.name }}</label>
        <select name="options[{{ option.name }}]" required>
            <option value="" disabled selected>Choose your size</option>
            {% for value in option.values %}
              <option value="{{ value }}">{{ value }}</option>
            {% endfor %}
          </select>
      </div>
    {% endif %}
  {% endfor %}

  <input type="hidden" name="id" value="{{ product.variants.first.id }}">
  <button type="submit" class="popup-atc">Add to Cart <span class="btn-icon">
      {{ 'right-arrow-icon.svg' | inline_asset_content }}</span></button>
    
</form>
</div>

<style>
    .popup-top {
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    gap: 1rem;
}
.popup-lft-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.popup-rit-content h3 {
    margin: 0;
    font-family: "Jost";
    font-weight: 300;
    font-style: Light;
    font-size: 16px;
    leading-trim: NONE;
    line-height: 120%;
    letter-spacing: 0px;
    vertical-align: middle;
}
.popup-price {
    margin: 8px auto;
    font-family: "Lustria";
    font-weight: 400;
    font-style: Regular;
    font-size: 16px;
    leading-trim: NONE;
    line-height: 120%;
    letter-spacing: 0px;
    vertical-align: middle;
}
.popup-rit-content p {
    font-family: "Jost";
    font-weight: 300;
    font-style: Light;
    font-size: 14px;
    leading-trim: NONE;
    line-height: 110.00000000000001%;
    letter-spacing: -1%;
}
.popup-form { margin-top: 15px; }
.popup-form select { width: 100%; padding: 6px; margin: 5px 0; }
.popup-atc {
  width: 100%;
  padding: 12px;
  background: #000;
  color: #fff;
  border: none;
  cursor: pointer;
  margin-top: 10px;
  /* font-weight: bold; */
  position: relative;
}
span.btn-icon {
    position: absolute;
    right: 30px;
}
button.popup-atc:hover {
    background: #fff544;
    color: #000;
}
button.popup-atc:hover span.btn-icon svg path {
    fill: #000 !important;
}
.popup-option.button_option {
    display: flex;
    flex-flow: column;
}
.popup-color-buttons {
   display: grid;
    grid-template-columns: 1fr 1fr;
}
.popup-form select {
    width: 100%;
    padding: 6px;
    margin: 5px 0;
    border: 1px solid #000;
}
</style>
<script>
document.addEventListener("DOMContentLoaded", function () {
  const form = document.querySelector(".popup-form");
  if (!form) return;

  const variants = {{ product.variants | json }};
  const variantField = form.querySelector(".popup-variant-id");
  const colorButtons = form.querySelectorAll(".popup-color-btn");
  const sizeSelect = form.querySelector(".popup-size-select");

  let selected = {};

  // color buttons
  colorButtons.forEach(btn => {
    btn.addEventListener("click", function() {
      selected['Color'] = this.dataset.value;
      colorButtons.forEach(b => b.classList.remove("active"));
      this.classList.add("active");
      updateVariant();
    });
  });

  // size dropdown
  if (sizeSelect) {
    sizeSelect.addEventListener("change", function() {
      selected['Size'] = this.value;
      updateVariant();
    });
  }

  function updateVariant() {
    const found = variants.find(v => {
      return Object.values(selected).every(val => v.options.includes(val));
    });
    variantField.value = found ? found.id : "";
  }
});
</script>

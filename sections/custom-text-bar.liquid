<style>
    .custom-text-bar {
  width: 100%;
  background: var(--bg-color);
  color: var(--text-color);

  min-height: var(--bar-height);

  display: flex;
  align-items: center;
  justify-content: center;

  padding:
    var(--padding-top)
    var(--padding-left)
    var(--padding-bottom);

  text-align: center;
}

.custom-text-bar__text {
  margin: 0;
  width: 100%;

  font-size: var(--font-size-desktop);
  font-weight: var(--font-weight);
  letter-spacing: var(--letter-spacing);
  line-height: var(--line-height);

  word-break: break-word;
}

@media (max-width: 989px) {
  .custom-text-bar__text {
    font-size: var(--font-size-tablet);
  }
}

@media (max-width: 749px) {
  .custom-text-bar {
    padding:
      calc(var(--padding-top) * 0.8)
      calc(var(--padding-left) * 0.8)
      calc(var(--padding-bottom) * 0.8);
  }

  .custom-text-bar__text {
    font-size: var(--font-size-mobile);
  }
}
</style>


<div
  class="custom-text-bar"
  style="
    --bar-height: {{ section.settings.bar_height }}px;
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
    --padding-left: {{ section.settings.padding_horizontal }}px;
    --font-size-desktop: {{ section.settings.desktop_font_size }}px;
    --font-size-tablet: {{ section.settings.tablet_font_size }}px;
    --font-size-mobile: {{ section.settings.mobile_font_size }}px;
    --font-weight: {{ section.settings.font_weight }};
    --letter-spacing: {{ section.settings.letter_spacing }}px;
    --line-height: {{ section.settings.line_height }};
    --bg-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
  "
>
  <div class="page-width">
    <p class="custom-text-bar__text">
      {{ section.settings.text }}
    </p>
  </div>
</div>



{% schema %}
{
    "name": "custom text bar",
    "settings": [
        {
  "type": "range",
  "id": "bar_height",
  "label": "Bar Height",
  "min": 30,
  "max": 150,
  "step": 2,
  "unit": "px",
  "default": 40
},
{
  "type": "range",
  "id": "padding_top",
  "label": "Padding Top",
  "min": 0,
  "max": 50,
  "step": 2,
  "unit": "px",
  "default": 8
},
{
  "type": "range",
  "id": "padding_bottom",
  "label": "Padding Bottom",
  "min": 0,
  "max": 50,
  "step": 2,
  "unit": "px",
  "default": 8
},
{
  "type": "range",
  "id": "padding_horizontal",
  "label": "Horizontal Padding",
  "min": 0,
  "max": 60,
  "step": 2,
  "unit": "px",
  "default": 15
},
{
  "type": "range",
  "id": "font_weight",
  "label": "Font Weight",
  "min": 100,
  "max": 900,
  "step": 100,
  "default": 500
},
{
  "type": "range",
  "id": "letter_spacing",
  "label": "Letter Spacing",
  "min": 0,
  "max": 10,
  "step": 0.5,
  "unit": "px",
  "default": 0.5
},
{
  "type": "range",
  "id": "line_height",
  "label": "Line Height",
  "min": 1,
  "max": 2,
  "step": 0.1, 
  "default": 1.4
}
        
        ],
"presets": [
    {
        "name": "Custom Text Bar"
    }
]
}
{% endschema %}
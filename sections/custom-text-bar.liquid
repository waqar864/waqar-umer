<style>
    .custom-text-bar {
  width: 100%;
  background: var(--bg-color);
  color: var(--text-color);

  min-height: var(--bar-height);

  display: flex;
  align-items: center;
  justify-content: center;

  padding:
    var(--padding-top)
    var(--padding-left)
    var(--padding-bottom);

  text-align: center;
}

.custom-text-bar__text {
  margin: 0;
  width: 100%;

  font-size: var(--font-size-desktop);
  font-weight: var(--font-weight);
  letter-spacing: var(--letter-spacing);
  line-height: var(--line-height);

  word-break: break-word;
}

@media (max-width: 989px) {
  .custom-text-bar__text {
    font-size: var(--font-size-tablet);
  }
}

@media (max-width: 749px) {
  .custom-text-bar {
    padding:
      calc(var(--padding-top) * 0.8)
      calc(var(--padding-left) * 0.8)
      calc(var(--padding-bottom) * 0.8);
  }

  .custom-text-bar__text {
    font-size: var(--font-size-mobile);
  }
}
</style>


<div
  class="custom-text-bar"
  style="
    --bar-height: {{ section.settings.bar_height }}px;
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
    --padding-left: {{ section.settings.padding_horizontal }}px;
    --font-size-desktop: {{ section.settings.desktop_font_size }}px;
    --font-size-tablet: {{ section.settings.tablet_font_size }}px;
    --font-size-mobile: {{ section.settings.mobile_font_size }}px;
    --font-weight: {{ section.settings.font_weight }};
    --letter-spacing: {{ section.settings.letter_spacing }}px;
    --line-height: {{ section.settings.line_height }};
    --bg-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
  "
>
  <div class="page-width">
    <p class="custom-text-bar__text">
      {{ section.settings.text }}
    </p>
  </div>
</div>



{% schema %}
{
  "name": "Responsive Text Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "desktop_font_size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Desktop Font Size",
      "default": 16
    },
    {
      "type": "range",
      "id": "tablet_font_size",
      "min": 10,
      "max": 36,
      "step": 1,
      "unit": "px",
      "label": "Tablet Font Size",
      "default": 14
    },
    {
      "type": "range",
      "id": "mobile_font_size",
      "min": 8,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Mobile Font Size",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Custom Text Bar"
    }
  ]
}
{% endschema %}
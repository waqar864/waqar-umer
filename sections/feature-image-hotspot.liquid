<style>
.featured-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(375px, 1fr));
  gap: 15px;
}

.featured-item {
  position: relative;
}

.featured-item img {
  width: 100%;
  display: block;
  /* border-radius: 6px; */
}

.hotspot {
  position: absolute;
  transform: translate(-50%, -50%);
  background: #f5f5f5;
  color: #000;
  border: none;
  border-radius: 50%;
  width: 22px;
  height: 22px;
  font-size: 16px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s ease;
}
.hotspot:hover {
  background: #444;
  color: #fff;
} 

/* Overlay */
.product-popup-overlay {
  display: none;
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0,0,0,0.6);
  z-index: 999;
}

/* Popup */
.product-popup {
  display: none;
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  background: #fff;
  padding: 20px;
  max-width: 325px;
  width: 90%;
  z-index: 1000;
  
  box-shadow: 0 10px 30px rgba(0,0,0,0.2);
}

.popup-close {
  position: absolute;
  top: 10px;
  right: 12px;
  font-size: 20px;
  background: none;
  border: none;
  cursor: pointer;
}

.popup-content {
  margin-top: 10px;
}
@media screen and (max-width: 767px) {
    .featured-grid{        
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)) !important;
        gap: 5px !important;
    }
}
</style>


<div class="page-width main-feature-spot">
    <div class="sec-title">
          {%- if section.settings.title != blank -%}
        <h2 class="title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {{ section.settings.title }}
        </h2>
      {%- endif -%}
    </div>
    <div class="featured-grid">
      {% for block in section.blocks %}
        {% assign product = all_products[block.settings.product] %}
        <div class="featured-item">
          {% if block.settings.image %}
            <img src="{{ block.settings.image | img_url: '600x600' }}" alt="">
            {% if product %}
            <button 
              class="hotspot" 
              style="top: {{ block.settings.top }}%; left: {{ block.settings.left }}%;" 
              data-product-handle="{{ product.handle }}">
              +
            </button> 
            {% endif %}
          {% endif %}
        </div>
      {% endfor %}
    </div>


</div>
{% comment %} model popup {% endcomment %}

<div class="product-popup-overlay" id="productPopupOverlay"></div>
<div class="product-popup" id="productPopup">
  <button class="popup-close" id="popupClose">×</button>
  <div class="popup-content" id="popupContent"></div>
</div>

{% schema %}
{
  "name": "Featured Images Hotspots",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "t:sections.featured-collection.settings.title.default",
      "label": "t:sections.featured-collection.settings.title.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    }
  ],
  "blocks": [
    {
      "type": "featured_image",
      "name": "Featured Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "range",
          "id": "top",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Hotspot Top Position",
          "default": 50
        },
        {
          "type": "range",
          "id": "left",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Hotspot Left Position",
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Hotspot Grid",
      "category": "Custom"
    }
  ]
}
{% endschema %}
